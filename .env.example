# Amazon SES SMTP credentials (Console → SES → SMTP settings → Create SMTP
# credentials). These are SMTP-specific, NOT your AWS access key/secret, and
# are region-specific. Keep them SECRET — only read server-side. See
# docs/aws-ses-setup.md.
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=xxxxxxxxxxxxxxxxxxxx
SES_SMTP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# Verified sender address (must be on a domain verified in SES).
DEARLY_FROM_EMAIL="Dearly <noreply@dearlyvoice.com>"

# Where waitlist signups get emailed to (your inbox).
WAITLIST_NOTIFY_EMAIL=you@yourdomain.com

# Canonical public site URL for auth email links (signup confirm, password reset).
# Set per environment: https://dearlyvoice.com (prod), https://dev.dearlyvoice.com (dev).
# Omit locally to use http://localhost:3000 from the browser.
NEXT_PUBLIC_SITE_URL=https://dearlyvoice.com

# Dev only: set to true to skip the login redirects on /inbox, /sent and
# /compose so every page can be opened without a session. Only honored when
# NODE_ENV is development (`npm run dev`) — it has no effect in production.
DEARLY_SKIP_AUTH=false

# Supabase (Dearly accounts: auth, database, audio storage).
# Project settings → API. The service-role key is SERVER-ONLY — never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
